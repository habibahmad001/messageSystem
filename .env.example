# Environment Configuration
NODE_ENV=DEVELOPMENT
PORT=5001
KEY=your_api_key_here

# Webhook Configuration (Optional)
WEBHOOK_BASE_URL=https://yourdomain.com/webhook

# Database Configuration (For Railway/Production)
# Railway will automatically provide these when you add a database service
# DATABASE_URL=mysql://user:password@host:port/database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mywhatsapp

# For Railway deployment, add a MySQL database service and Railway will provide:
# DATABASE_URL, MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD